# .env.example
# Template for required environment variables.
# Copy this file to ".env" and fill in real values. Never commit the real
# ".env" file. These are the account settings and credentials the engine
# needs to place calls, hear, think, and speak. No real secrets here.

# Google Cloud / Vertex AI: where the Gemini Live and text models run.
GOOGLE_CLOUD_PROJECT=plotpointe                  # The GCP project id that hosts the models.
GOOGLE_CLOUD_LOCATION=global                     # The GCP location for the models. Use "global"; the Gemini Live API is served from the global endpoint.
GOOGLE_GENAI_USE_VERTEXAI=true                   # Tell the google-genai SDK to use Vertex AI, not the public API.
# GOOGLE_APPLICATION_CREDENTIALS is OPTIONAL if you have already run
# "gcloud auth application-default login" (Application Default Credentials).
# Only set it to authenticate with a service account key file instead.
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json  # Optional. Path to a service account JSON key file.

# Twilio: places the outbound call and streams the audio.
TWILIO_ACCOUNT_SID=your-twilio-account-sid       # Your Twilio account identifier.
TWILIO_AUTH_TOKEN=your-twilio-auth-token          # Your Twilio secret auth token.
TWILIO_FROM_NUMBER=+1-000-000-0000                # The Twilio number we dial out from.

# Target: the medical receptionist agent we are calling and testing.
TARGET_NUMBER=+1-805-439-8008                     # The phone number of the agent under test.
